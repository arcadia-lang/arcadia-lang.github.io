03c4\u03bf\u03b9\u03c7\u03b5\u03af\u03b1 \u03c3\u03b5 \u03bc\u03b9\u03b1 \u03bb\u03af\u03c3\u03c4\u03b1 \u03ae \u03c4\u03b9\u03c2 \u03c0\u03c1\u03bf\u03c4\u03ac\u03c3\u03b5\u03b9\u03c2 \u03bc\u03ad\u03c3\u03b1 \u03c3\u03b5 \u03bc\u03b9\u03b1 \u03c0\u03c1\u03cc\u03c4\u03b1\u03c3\u03b7. : \u0394\u03b9\u03c0\u03bb\u03ae \u03a4\u03b5\u03bb\u03b5\u03af\u03b1 \u0395\u03b9\u03c3\u03ac\u03b3\u03b5\u03b9 \u03bc\u03b9\u03b1 \u03bb\u03af\u03c3\u03c4\u03b1, \u03c0\u03b1\u03c1\u03ac\u03b8\u03b5\u03c3\u03b7 \u03ae \u03b5\u03be\u03ae\u03b3\u03b7\u03c3\u03b7. ! \u0398\u03b1\u03c5\u03bc\u03b1\u03c3\u03c4\u03b9\u03ba\u03cc \u0395\u03ba\u03c6\u03c1\u03ac\u03b6\u03b5\u03b9 \u03ad\u03bd\u03c4\u03bf\u03bd\u03b1 \u03c3\u03c5\u03bd\u03b1\u03b9\u03c3\u03b8\u03ae\u03bc\u03b1\u03c4\u03b1 \u03ae \u03bc\u03b9\u03b1 \u03b5\u03bd\u03c4\u03bf\u03bb\u03ae. ? \u0395\u03c1\u03c9\u03c4\u03b7\u03bc\u03b1\u03c4\u03b9\u03ba\u03cc \u0394\u03b7\u03bb\u03ce\u03bd\u03b5\u03b9 \u03bc\u03b9\u03b1 \u03b5\u03c1\u03ce\u03c4\u03b7\u03c3\u03b7. \"\" \u0394\u03b9\u03c0\u03bb\u03ac \u0395\u03b9\u03c3\u03b1\u03b3\u03c9\u03b3\u03b9\u03ba\u03ac \u03a0\u03b5\u03c1\u03b9\u03ba\u03bb\u03b5\u03af\u03bf\u03c5\u03bd \u03ac\u03bc\u03b5\u03c3\u03b5\u03c2 \u03bf\u03bc\u03b9\u03bb\u03af\u03b5\u03c2, \u03c0\u03b1\u03c1\u03b1\u03b8\u03ad\u03c3\u03b5\u03b9\u03c2 \u03ae \u03c4\u03af\u03c4\u03bb\u03bf\u03c5\u03c2."},{"location":"verbs/","title":"Index","text":"<p>\ud83d\udea7 \u0397 \u03c3\u03b5\u03bb\u03af\u03b4\u03b1 \u03b2\u03c1\u03af\u03c3\u03ba\u03b5\u03c4\u03b1\u03b9 \u03c5\u03c0\u03cc \u03ba\u03b1\u03c4\u03b1\u03c3\u03ba\u03b5\u03c5\u03ae</p>"},{"location":"verbs/aspect/","title":"\u038c\u03c8\u03b7","text":"<p>\ud83d\udea7 \u0397 \u03c3\u03b5\u03bb\u03af\u03b4\u03b1 \u03b2\u03c1\u03af\u03c3\u03ba\u03b5\u03c4\u03b1\u03b9 \u03c5\u03c0\u03cc \u03ba\u03b1\u03c4\u03b1\u03c3\u03ba\u03b5\u03c5\u03ae</p>"},{"location":"verbs/category/","title":"\u039a\u03b1\u03c4\u03b7\u03b3\u03bf\u03c1\u03af\u03b1","text":"<p>\ud83d\udea7 \u0397 \u03