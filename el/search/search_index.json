t":"<p>\ud83d\udea7 \u0397 \u03c3\u03b5\u03bb\u03af\u03b4\u03b1 \u03b2\u03c1\u03af\u03c3\u03ba\u03b5\u03c4\u03b1\u03b9 \u03c5\u03c0\u03cc \u03ba\u03b1\u03c4\u03b1\u03c3\u03ba\u03b5\u03c5\u03ae</p>"},{"location":"nouns/class/","title":"\u03a4\u03ac\u03be\u03b7","text":"<p>\ud83d\udea7 \u0397 \u03c3\u03b5\u03bb\u03af\u03b4\u03b1 \u03b2\u03c1\u03af\u03c3\u03ba\u03b5\u03c4\u03b1\u03b9 \u03c5\u03c0\u03cc \u03ba\u03b1\u03c4\u03b1\u03c3\u03ba\u03b5\u03c5\u03ae</p>"},{"location":"nouns/declension/","title":"\u03a0\u03af\u03bd\u03b1\u03ba\u03b5\u03c2 \u03ba\u03bb\u03af\u03c3\u03b7\u03c2","text":"<p>\ud83d\udea7 \u0397 \u03c3\u03b5\u03bb\u03af\u03b4\u03b1 \u03b2\u03c1\u03af\u03c3\u03ba\u03b5\u03c4\u03b1\u03b9 \u03c5\u03c0\u03cc \u03ba\u03b1\u03c4\u03b1\u03c3\u03ba\u03b5\u03c5\u03ae</p>"},{"location":"nouns/gender/","title":"\u0393\u03ad\u03bd\u03bf\u03c2","text":"<p>\ud83d\udea7 \u0397 \u03c3\u03b5\u03bb\u03af\u03b4\u03b1 \u03b2\u03c1\u03af\u03c3\u03ba\u03b5\u03c4\u03b1\u03b9 \u03c5\u03c0\u03cc \u03ba\u03b1\u03c4\u03b1\u03c3\u03ba\u03b5\u03c5\u03ae</p>"},{"location":"nouns/number/","title":"\u0391\u03c1\u03b9\u03b8\u03bc\u03cc\u03c2","text":"<p>\ud83d\udea7 \u0397 \u03c3\u03b5\u03bb\u03af\u03b4\u03b1 \u03b2\u03c1\u03af\u03c3\u03ba\u03b5\u03c4\u03b1\u03b9 \u03c5\u03c0\u03cc \u03ba\u03b1\u03c4\u03b1\u03c3\u03ba\u03b5\u03c5\u03ae</p>"},{"location":"orthography/","title":"\u039f\u03c1\u03b8\u03bf\u03b3\u03c1\u03b1\u03c6\u03af\u03b1 \u03ba\u03b1\u03b9 \u03a6\u03c9\u03bd\u03bf\u03bb\u03bf\u03b3\u03af\u03b1 \u03c4\u03b7\u03c2 \u0391\u03c1\u03ba\u03ac\u03b4\u03b9\u03b1","text":"<p>\u0397 \u0391\u03c1\u03ba\u03ac\u03b4\u03b9\u03b1 \u03b4\u03b9\u03b1\u03c4\u03b7\u03c1\u03b5\u03af \u03bc\u03b9\u03b1 \u03ad\u03bd\u03b1 \u03c0\u03c1\u03bf\u03c2 \u03ad\u03bd\u03b1 \u03b1\u03bd\u03c4\u03b9\u03c3\u03c4\u03bf\u03b9\u03c7\u03af\u03b1 \u03bc\u03b5\u03c4\u03b1\u03be\u03cd \u03c4\u03bf\u03c5 \u03b3\u03c1\u03b1\u03c0\u03c4\u03bf\u03cd \u03ba\u03b1\u03b9 \u03c4\u03bf\u03c5 \u03c0\u03c1\u03bf\u03c6\u03bf\u03c1\u03b9\u03ba\u03bf\u03cd \u03bb\u03cc\u03b3\u03bf\u03c5, \u03b5\u03be\u03b1\u03c3\u03c6\u03b1\u03bb\u03af\u03b6\u03bf\u03bd\u03c4\u03b1\u03c2 \u03c3\u03b1\u03c6\u03ae\u03bd\u03b5\u03b9\u03b1 \u03b5\u03bd\u03ce \u03b5\u03c0\u03b9\u03c4\u03c1\u03ad\u03c0\u03b5\u03b9 \u03b5\u03c5\u03b5\u03bb\u03b9\u03be\u03af\u03b1 \u03c3\u03c4\u03b9\u03c2 \u03c0\u03b1\u03c1\u03b1\u03bb\u03bb\u03b1\u03b3\u03ad\u03c2 \u03c4\u03bf\u03bd\u03b9\u03c3\u03bc\u03bf\u03cd. \u0397 \u03b3\u03bb\u03ce\u03c3\u03c3\u03b1 \u03c7\u03c1\u03b7\u03c3\u03b9\u03bc\u03bf\u03c0\u03bf\u03b9\u03b5\u03af 23 \u03bb\u03b1\u03c4\u03b9\u03bd\u03b9\u03ba\u03ac \u03b3\u03c1\u03ac\u03bc\u03bc\u03b1\u03c4\u03b1, \u03b5\u03be\u03b1\u03b9\u03c1\u03bf\u03c5\u03bc\u03ad\u03bd\u03c9\u03bd \u03c4\u03c9\u03bd \u27e8k\u27e9, \u27e8q\u27e9, \u03ba\u03b1\u03b9 \u27e8w\u27e9, \u03ba\u03b1\u03b8\u03ce\u03c2 \u03ba\u03b1\u03b9 \u03b4\u03af\u03c8\u03b7\u03c6\u03b1 \u03c3\u03cd\u03bc\u03c6\u03c9\u03bd\u03b1 \u03ba\u03b1\u03b9 \u03ba\u03b1\u03bb\u03ac \u03ba\u03b1\u03b8\u03bf\u03c1\u03b9\u03c3\u03bc\u03ad\u03bd\u03bf\u03c5\u03c2 \u03ba\u03b1\u03bd\u03cc\u03bd\u03b5\u03c2 \u03c4\u03bf\u03bd\u03b9\u03c3\u03bc\u03bf\u03cd \u03b3\u03b9\u03b1 \u03c4\u03b7 \u03b4\u03b9\u03b1\u03c4\u03ae\u03c1\u03b7\u03c3\u03b7 \u03c4\u03b7\u03c2 \u03bf\u03bc\u03bf\u03b9\u03bf\u03bc\u03bf\u03c1\u03c6\u03af\u03b1\u03c2. \u0394\u03b5\u03bd \u03c5\u03c0\u03ac\u03c1\u03c7\u03bf\u03c5\u03bd \u03c3\u03b9\u03c9\u03c0\u03b7\u03bb\u03ac \u03b3\u03c1\u03ac\u03bc\u03bc\u03b1\u03c4\u03b1 \u03ae \u03ba\u03b5\u03c6\u03b1\u03bb\u03b1\u03af\u03b1 \u03c3\u03c4\u03b7\u03bd \u0391\u03c1\u03ba\u03ac\u03b4\u03b9\u03b1.</p> <p>\u0388\u03bd\u03b1\u03c2 \u03c0\u03bb\u03ae\u03c1\u03b7\u03c2 \u03c0\u03af\u03bd\u03b1\u03ba\u03b1\u03c2 \u03c0\u03c1\u03bf\u03c6\u03bf\u03c1\u03ac\u03c2 \u03b3\u03b9\u03b1 \u03ba\u03ac\u03b8\u03b5 \u03b3\u03c1\u03ac\u03bc\u03bc\u03b1 \u03ba\u03b1\u03b9 \u03b4\u03af\u03c8\u03b7\u03c6\u03bf \u03c3\u03cd\u03bc\u03c6\u03c9\u03bd\u03bf \u03b2\u03c1\u03af\u03c3\u03ba\u03b5\u03c4\u03b1\u03b9 \u03b5\u03b4\u03ce.</p> <p>\u039f \u03ae\u03c7\u03bf\u03c2 /ks/ \u03b3\u03c1\u03ac\u03c6\u03b5\u03c4\u03b1\u03b9 \u03c0\u03ac\u03bd\u03c4\u03b1 \u03c9\u03c2 \u27e8x\u27e9 \u03ba\u03b1\u03b9 \u03c0\u03bf\u03c4\u03ad \u03c9\u03c2 \u27e8cs\u27e9.</p> <p>\u0395\u03c5\u03b5\u03bb\u03b9\u03be\u03af\u03b1 \u03a0\u03c1\u03bf\u03c6\u03bf\u03c1\u03ac\u03c2</p> <p>\u0397 \u0391\u03c1\u03ba\u03ac\u03b4\u03b9\u03b1 \u03b5\u03c0\u03b9\u03c4\u03c1\u03ad\u03c0\u03b5\u03b9 \u03ad\u03bd\u03b1 \u03b5\u03c5\u03c1\u03cd \u03c6\u03ac\u03c3\u03bc\u03b1 \u03c6\u03c9\u03bd\u03b7\u03c4\u03b9\u03ba\u03ce\u03bd \u03c0\u03b1\u03c1\u03b1\u03bb\u03bb\u03b1\u03b3\u03ce\u03bd \u03b4\u03b9\u03b1\u03c4\u03b7\u03c1\u03ce\u03bd\u03c4\u03b1\u03c2 \u03c4\u03bf\u03c5\u03c2 \u03b2\u03b1\u03c3\u03b9\u03ba\u03bf\u03cd\u03c2 \u03ae\u03c7\u03bf\u03c5\u03c2. \u0393\u03b9\u03b1 \u03c0\u03b1\u03c1\u03ac\u03b4\u03b5\u03b9\u03b3\u03bc\u03b1, \u03c4\u03bf \u27e8r\u27e9 \u03c0\u03c1\u03bf\u03c6\u03ad\u03c1\u03b5\u03c4\u03b1\u03b9 \u03c9\u03c2 /r/, \u03b1\u03bb\u03bb\u03ac \u03bf\u03b9 \u03b4\u03b9\u03b1\u03ba\u03c1\u03af\u03c3\u03b5\u03b9\u03c2 \u03bc\u03b5\u03c4\u03b1\u03be\u03cd \u03c4\u03bf\u03c5\u03c2 \u03b4\u03b5\u03bd \u03ad\u03c7\u03bf\u03c5\u03bd \u03bb\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03b9\u03ba\u03cc \u03c6\u03bf\u03c1\u03c4\u03af\u03bf. \u03a4\u03bf \u03c6\u03c9\u03bd\u03bf\u03bb\u03bf\u03b3\u03b9\u03ba\u03cc \u03c3\u03cd\u03c3\u03c4\u03b7\u03bc\u03b1 \u03ad\u03c7\u03b5\u03b9 \u03c3\u03c7\u03b5\u03b4\u03b9\u03b1\u03c3\u03c4\u03b5\u03af \u03b3\u03b9\u03b1 \u03b4\u03b9\u03b1\u03c0\u03bf\u03bb\u03b9\u03c4\u03b9\u03c3\u03bc\u03b9\u03ba\u03ae \u03c0\u03c1\u03bf\u03c3\u03b2\u03b1\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1, \u03b5\u03be\u03b1\u03c3\u03c6\u03b1\u03bb\u03af\u03b6\u03bf\u03bd\u03c4\u03b1\u03c2 \u03c6\u03c5\u03c3\u03b9\u03ba\u03ae \u03c0\u03b1\u03c1\u03b1\u03bb\u03bb\u03b1\u03b3\u03ae.</p> <p>\u03a4\u03bf \u03c3\u03cd\u03c3\u03c4\u03b7\u03bc\u03b1 \u03c3\u03b7\u03bc\u03b5\u03af\u03c9\u03bd \u03c3\u03c4\u03af\u03be\u03b7\u03c2 \u03c4\u03b7\u03c2 \u0391\u03c1\u03ba\u03ac\u03b4\u03b9\u03b1\u03c2, \u03bc\u03b1\u03b6\u03af \u03bc\u03b5 \u03c4\u03b9\u03c2 \u03c3\u03b7\u03bc\u03b1\u03c3\u03af\u03b5\u03c2 \u03ba\u03ac\u03b8\u03b5 \u03c3\u03b7\u03bc\u03b5\u03af\u03bf\u03c5, \u03b1\u03bd\u03b1\u03bb\u03cd\u03b5\u03c4\u03b1\u03b9 \u03c3\u03c4\u03b7\u03bd \u03b5\u03bd\u03cc\u03c4\u03b7\u03c4\u03b1 \u03a3\u03b7\u03bc\u03b5\u03af\u03b1 \u03c3\u03c4\u03af\u03be\u03b7\u03c2.</p>"},{"location":"orthography/#_2","title":"\u03a4\u03bf\u03bd\u03b9\u03c3\u03bc\u03cc\u03c2","text":"<p>\u039f\u03b9 \u03bc\u03bf\u03bd\u03bf\u03c3\u03cd\u03bb\u03bb\u03b1\u03b2\u03b5\u03c2 \u03bb\u03ad\u03be\u03b5\u03b9\u03c2 \u03b5\u03af\u03bd\u03b1\u03b9 \u03c0\u03ac\u03bd\u03c4\u03b1 \u03c4\u03bf\u03bd\u03b9\u03c3\u03bc\u03ad\u03bd\u03b5\u03c2 \u03c3\u03c4\u03b7 \u03bc\u03bf\u03bd\u03b1\u03b4\u03b9\u03ba\u03ae \u03c4\u03bf\u03c5\u03c2 \u03c3\u03c5\u03bb\u03bb\u03b1\u03b2\u03ae, \u03b5\u03be\u03b1\u03bb\u03b5\u03af\u03c6\u03bf\u03bd\u03c4\u03b1\u03c2 \u03c4\u03b7\u03bd \u03b1\u03bd\u03ac\u03b3\u03ba\u03b7 \u03b3\u03b9\u03b1 \u03c3\u03b7\u03bc\u03ac\u03b4\u03b9\u03b1 \u03c4\u03cc\u03bd\u03bf\u03c5 \u03c3\u03b5 \u03b1\u03c5\u03c4\u03ad\u03c2. \u0393\u03b9\u03b1 \u03c4\u03b9\u03c2 \u03c0\u03bf\u03bb\u03c5\u03c3\u03cd\u03bb\u03bb\u03b1\u03b2\u03b5\u03c2 \u03bb\u03ad\u03be\u03b5\u03b9\u03c2, \u03bf \u03c4\u03bf\u03bd\u03b9\u03c3\u03bc\u03cc\u03c2 \u03bc\u03c0\u03bf\u03c1\u03b5\u03af \u03bd\u03b1 \u03c0\u03ad\u03c3\u03b5\u03b9 \u03c3\u03c4\u03b7\u03bd \u03c4\u03b5\u03bb\u03b5\u03c5\u03c4\u03b1\u03af\u03b1, \u03c0\u03c1\u03bf\u03c4\u03b5\u03bb\u03b5\u03c5\u03c4\u03b1\u03af\u03b1 \u03ae \u03c0\u03c1\u03bf\u03c0\u03c1\u03bf\u03c4\u03b5\u03bb\u03b5\u03c5\u03c4\u03b1\u03af\u03b1 \u03c3\u03c5\u03bb\u03bb\u03b1\u03b2\u03ae.</p> <p>\u0393\u03b9\u03b1 \u03bd\u03b1 \u03b5\u03bb\u03b1\u03c7\u03b9\u03c3\u03c4\u03bf\u03c0\u03bf\u03b9\u03b7\u03b8\u03bf\u03cd\u03bd \u03bf\u03b9 \u03c4\u03cc\u03bd\u03bf\u03b9, \u03bc\u03cc\u03bd\u03bf \u03bf\u03b9 \u03bb\u03ad\u03be\u03b5\u03b9\u03c2 \u03c0\u03bf\u03c5 \u03b4\u03b5\u03bd \u03c4\u03bf\u03bd\u03af\u03b6\u03bf\u03bd\u03c4\u03b1\u03b9 \u03c3\u03c4\u03b7\u03bd \u03c0\u03c1\u03bf\u03c4\u03b5\u03bb\u03b5\u03c5\u03c4\u03b1\u03af\u03b1 \u03c3\u03c5\u03bb\u03bb\u03b1\u03b2\u03ae \u03b1\u03c0\u03b1\u03b9\u03c4\u03bf\u03cd\u03bd \u03c4\u03cc\u03bd\u03bf.</p> <ul> <li>\u03a7\u03c9\u03c1\u03af\u03c2 \u03c4\u03cc\u03bd\u03bf \u2192 \u039f \u03c4\u03bf\u03bd\u03b9\u03c3\u03bc\u03cc\u03c2 \u03c0\u03c1\u03bf\u03b5\u03c0\u03b9\u03bb\u03ad\u03b3\u03b5\u03c4\u03b1\u03b9 \u03c3\u03c4\u03b7\u03bd \u03c0\u03c1\u03bf\u03c4\u03b5\u03bb\u03b5\u03c5\u03c4\u03b1\u03af\u03b1 \u03c3\u03c5\u03bb\u03bb\u03b1\u03b2\u03ae (ho.mis \u2192 /'homis/).</li> <li>\u039f\u03be\u03b5\u03af\u03b1 (\u00b4) \u2192 \u0394\u03b7\u03bb\u03ce\u03bd\u03b5\u03b9 \u03c4\u03bf\u03bd\u03b9\u03c3\u03bc\u03cc \u03c3\u03c4\u03b7\u03bd \u03c4\u03bf\u03bd\u03b9\u03c3\u03bc\u03ad\u03bd\u03b7 \u03c3\u03c5\u03bb\u03bb\u03b1\u03b2\u03ae (a.s\u00e9 \u2192 /a'se/).</li> </ul>"},{"location":"orthography/#_3","title":"\u03a3\u03c5\u03b3\u03c7\u03ce\u03bd\u03b5\u03c5\u03c3\u03b7 \u03c6\u03c9\u03bd\u03b7\u03ad\u03bd\u03c4\u03c9\u03bd","text":"<p>\u03a4\u03b1 \u03b4\u03b9\u03b1\u03b4\u03bf\u03c7\u03b9\u03ba\u03ac \u03cc\u03bc\u03bf\u03b9\u03b1 \u03c6\u03c9\u03bd\u03ae\u03b5\u03bd\u03c4\u03b1 \u03c3\u03c5\u03b3\u03c7\u03c9\u03bd\u03b5\u03cd\u03bf\u03bd\u03c4\u03b1\u03b9 (mee \u2192 m\u0113), \u03b1\u03bb\u03bb\u03ac \u03c4\u03b1 \u03c3\u03c5\u03b3\u03c7\u03c9\u03bd\u03b5\u03c5\u03bc\u03ad\u03bd\u03b1 \u03c6\u03c9\u03bd\u03ae\u03b5\u03bd\u03c4\u03b1 \u03c3\u03c5\u03bd\u03ae\u03b8\u03c9\u03c2 \u03b3\u03c1\u03ac\u03c6\u03bf\u03bd\u03c4\u03b1\u03b9 \u03c3\u03c4\u03b7\u03bd \u03b1\u03c0\u03bb\u03bf\u03c0\u03bf\u03b9\u03b7\u03bc\u03ad\u03bd\u03b7 \u03bc\u03bf\u03c1\u03c6\u03ae \u03c4\u03bf\u03c5\u03c2 (me). \u0388\u03bd\u03b1 \u03bc\u03b1\u03ba\u03c1\u03cc (\u00af) \u03c7\u03c1\u03b7\u03c3\u03b9\u03bc\u03bf\u03c0\u03bf\u03b9\u03b5\u03af\u03c4\u03b1\u03b9 \u03bc\u03cc\u03bd\u03bf \u03c3\u03b5 \u03bb\u03b5\u03be\u03b9\u03ba\u03ac \u03ae \u03b3\u03c1\u03b1\u03bc\u03bc\u03b1\u03c4\u03b9\u03ba\u03ad\u03c2 \u03b1\u03bd\u03b1\u03c6\u03bf\u03c1\u03ad\u03c2 \u03b3\u03b9\u03b1 \u03bd\u03b1 \u03b4\u03b7\u03bb\u03ce\u03c3\u03b5\u03b9 \u03c4\u03b7 \u03c3\u03c5\u03b3\u03c7\u03ce\u03bd\u03b5\u03c5\u03c3\u03b7 \u03c6\u03c9\u03bd\u03b7\u03ad\u03bd\u03c4\u03c9\u03bd.</p>"},{"location":"orthography/#_4","title":"\u03a3\u03b7\u03bc\u03b5\u03af\u03b1 \u03c3\u03c4\u03af\u03be\u03b7\u03c2","text":"<p>\u0395\u03ac\u03bd \u03bc\u03b9\u03b1 \u03c0\u03b1\u03c1\u03b1\u03c4\u03b9\u03b8\u03ad\u03bc\u03b5\u03bd\u03b7 \u03c0\u03c1\u03cc\u03c4\u03b1\u03c3\u03b7 \u03c4\u03b5\u03bb\u03b5\u03b9\u03ce\u03bd\u03b5\u03b9 \u03bc\u03b5 \u03c4\u03bf \u03af\u03b4\u03b9\u03bf \u03c3\u03b7\u03bc\u03b5\u03af\u03bf \u03c3\u03c4\u03af\u03be\u03b7\u03c2 \u03cc\u03c0\u03c9\u03c2 \u03b7 \u03ba\u03cd\u03c1\u03b9\u03b1 \u03c0\u03c1\u03cc\u03c4\u03b1\u03c3\u03b7, \u03c4\u03bf \u03c3\u03b7\u03bc\u03b5\u03af\u03bf \u03c3\u03c4\u03af\u03be\u03b7\u03c2 \u03c4\u03bf\u03c0\u03bf\u03b8\u03b5\u03c4\u03b5\u03af\u03c4\u03b1\u03b9 \u03bc\u03cc\u03bd\u03bf \u03ad\u03be\u03c9 \u03b1\u03c0\u03cc \u03c4\u03b7\u03bd \u03c0\u03b1\u03c1\u03ac\u03b8\u03b5\u03c3\u03b7:</p> <ul> <li>\u2705 \u0395\u03af\u03c0\u03b5, \u00ab\u0391\u03c5\u03c4\u03cc \u03b5\u03af\u03bd\u03b1\u03b9 \u03c3\u03c9\u03c3\u03c4\u03cc\u00bb.</li> <li>\u274c \u0395\u03af\u03c0\u03b5, \u00ab\u0391\u03c5\u03c4\u03cc \u03b5\u03af\u03bd\u03b1\u03b9 \u03c3\u03c9\u03c3\u03c4\u03cc.\u00bb.</li> </ul>"},{"location":"orthography/#_5","title":"\u0394\u03ac\u03bd\u03b5\u03b9\u03b1 \u03ba\u03b1\u03b9 \u039f\u03bd\u03cc\u03bc\u03b1\u03c4\u03b1","text":"<p>\u03a4\u03b1 \u03ba\u03cd\u03c1\u03b9\u03b1 \u03bf\u03bd\u03cc\u03bc\u03b1\u03c4\u03b1 \u03c0\u03bf\u03c5 \u03b4\u03b9\u03b1\u03c4\u03b7\u03c1\u03bf\u03cd\u03bd \u03c4\u03b7\u03bd \u03c4\u03c5\u03c0\u03b9\u03ba\u03ae \u03bb\u03b1\u03c4\u03b9\u03bd\u03b9\u03ba\u03ae \u03bf\u03c1\u03b8\u03bf\u03b3\u03c1\u03b1\u03c6\u03af\u03b1 \u03c0\u03b1\u03c1\u03b1\u03bc\u03ad\u03bd\u03bf\u03c5\u03bd \u03b1\u03bc\u03b5\u03c4\u03ac\u03b2\u03bb\u03b7\u03c4\u03b1 (tokyo), \u03b1\u03ba\u03cc\u03bc\u03b7 \u03ba\u03b1\u03b9 \u03b1\u03bd \u03c0\u03b5\u03c1\u03b9\u03ad\u03c7\u03bf\u03c5\u03bd \u27e8k\u27e9, \u27e8q\u27e9 \u03ae \u27e8w\u27e9. \u0395\u03c0\u03af\u03c3\u03b7\u03c2, \u03bf\u03b9 \u03c4\u03c5\u03c0\u03b9\u03ba\u03ad\u03c2 \u03bc\u03bf\u03bd\u03ac\u03b4\u03b5\u03c2 \u03bc\u03ad\u03c4\u03c1\u03b7\u03c3\u03b7\u03c2 \u03ba\u03b1\u03b9 \u03c4\u03b1 \u03c3\u03cd\u03bc\u03b2\u03bf\u03bb\u03b1 \u03c7\u03c1\u03b7\u03c3\u03b9\u03bc\u03bf\u03c0\u03bf\u03b9\u03bf\u03cd\u03bd\u03c4\u03b1\u03b9 \u03c7\u03c9\u03c1\u03af\u03c2 \u03c4\u03c1\u03bf\u03c0\u03bf\u03c0\u03bf\u03af\u03b7\u03c3\u03b7, \u03b1\u03ba\u03cc\u03bc\u03b7 \u03ba\u03b1\u03b9 \u03b1\u03bd \u03c0\u03b5\u03c1\u03b9\u03ad\u03c7\u03bf\u03c5\u03bd \u03ba\u03b5\u03c6\u03b1\u03bb\u03b1\u03af\u03b1 \u03b3\u03c1\u03ac\u03bc\u03bc\u03b1\u03c4\u03b1, \u03c0.\u03c7. kWh.</p> <p>\u0393\u03b9\u03b1 \u03bd\u03b1 \u03c4\u03b7\u03bd \u03b4\u03b9\u03b5\u03c5\u03ba\u03cc\u03bb\u03c5\u03bd\u03c3\u03b7 \u03c4\u03bf\u03c5 \u03b1\u03bd\u03b1\u03b3\u03bd\u03ce\u03c3\u03c4\u03b7, \u03bc\u03c0\u03bf\u03c1\u03b5\u03af \u03bd\u03b1 \u03c7\u03c1\u03b7\u03c3\u03b9\u03bc\u03bf\u03c0\u03bf\u03b9\u03b7\u03b8\u03b5\u03af \u03b7 \u03b4\u03b9\u03c0\u03bb\u03ae \u03ac\u03bd\u03c9 \u03c4\u03b5\u03bb\u03b5\u03af\u03b1 (::) \u03c3\u03c4\u03b7\u03bd \u03c0\u03c1\u03ce\u03c4\u03b7 \u03b5\u03bc\u03c6\u03ac\u03bd\u03b9\u03c3\u03b7 \u03b5\u03bd\u03cc\u03c2 \u03c4\u03ad\u03c4\u03bf\u03b9\u03bf\u03c5 \u03bf\u03bd\u03cc\u03bc\u03b1\u03c4\u03bf\u03c2 (mike ::maic::).</p>"},{"location":"orthography/letters/","title":"Letters","text":"Letter IPA English Approximation a /a/ hat b /b/ aback c /k/ kite d /d/ dog e /e/ set f /f/ fish g /g/ get h /h/ honey i /i/ ship j /d\u035c\u0292/ jam l /l/ lamp m /m/ man n /n/ not o /o/ cross p /p/ pan r /r/ run s /s/ sun t /t/ tap u /u/ blue v /v/ van x /ks/ tax y /j/ yes z /z/ zoo"},{"location":"orthography/letters/#digraphs","title":"Digraphs","text":"Digraph IPA English Approximation ch /t\u035cs/ chair dh /\u00f0/ there th /\u03b8/ thanks"},{"location":"orthography/punctuation/","title":"Punctuation","text":"Punctuation Mark Name Usage . Period Ends a declarative sentence. ; Semicolon Connects related independent clauses or separates items in a complex list. , Comma Separates elements in a list or clauses within a sentence. : Colon Introduces a list, quotation, or explanation. ! Exclamation Mark Expresses strong emotion or a command. ? Question Mark Marks a question. \"\" Quotation Marks Encloses direct speech, quotations, or titles."},{"location":"pronouns/","title":"Index","text":"<p>\ud83d\udea7 \u0397 \u03c3\u03b5\u03bb\u03af\u03b4\u03b1 \u03b2\u03c1\u03af\u03c3\u03ba\u03b5\u03c4\u03b1\u03b9 \u03c5\u03c0\u03cc \u03ba\u03b1\u03c4\u03b1\u03c3\u03ba\u03b5\u03c5\u03ae</p>"},{"location":"pronouns/impersonal/","title":"\u0391\u03c0\u03c1\u03cc\u03c3\u03c9\u03c0\u03b5\u03c2 \u03b1\u03bd\u03c4\u03c9\u03bd\u03c5\u03bc\u03af\u03b5\u03c2","text":"<p>\ud83d\udea7 \u0397 \u03c3\u03b5\u03bb\u03af\u03b4\u03b1 \u03b2\u03c1\u03af\u03c3\u03ba\u03b5\u03c4\u03b1\u03b9 \u03c5\u03c0\u03cc \u03ba\u03b1\u03c4\u03b1\u03c3\u03ba\u03b5\u03c5\u03ae</p>"},{"location":"pronouns/personal/","title":"\u03a0\u03c1\u03bf\u03c3\u03c9\u03c0\u03b9\u03ba\u03ad\u03c2 \u03b1\u03bd\u03c4\u03c9\u03bd\u03c5\u03bc\u03af\u03b5\u03c2","text":"<p>\ud83d\udea7 \u0397 \u03c3\u03b5\u03bb\u03af\u03b4\u03b1 \u03b2\u03c1\u03af\u03c3\u03ba\u03b5\u03c4\u03b1\u03b9 \u03c5\u03c0\u03cc \u03ba\u03b1\u03c4\u03b1\u03c3\u03ba\u03b5\u03c5\u03ae</p>"},{"location":"verbs/","title":"Index","text":"<p>\ud83d\udea7 \u0397 \u03c3\u03b5\u03bb\u03af\u03b4\u03b1 \u03b2\u03c1\u03af\u03c3\u03ba\u03b5\u03c4\u03b1\u03b9 \u03c5\u03c0\u03cc \u03ba